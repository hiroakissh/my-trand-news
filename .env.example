# Gmail SMTP settings.
# Gmail requires a Google account app password, not the normal login password.
NEWS_MAIL_TO=your-address@gmail.com
NEWS_MAIL_FROM=your-address@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Optional runtime switches.
NEWS_DRY_RUN=false
NEWS_LOG_LEVEL=INFO
